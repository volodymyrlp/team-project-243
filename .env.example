# ============================================
#  Team Project #243 — environment variables example
#  Copy to .env and fill in. Never commit .env.
# ============================================

# --- Database (MySQL / Aiven) ---
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/travel
SPRING_DATASOURCE_USERNAME=travel
SPRING_DATASOURCE_PASSWORD=travel
# Production (Aiven): jdbc:mysql://<host>:<port>/<db>?sslMode=REQUIRED

# --- Nominatim (geocoding, called by the backend) ---
# User-Agent MUST include a real contact (Nominatim policy). Limit: 1 request/sec.
NOMINATIM_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=team243-travel-planner (contact: your-email@example.com)

# --- Routing (OpenRouteService) ---
ORS_API_KEY=your_ors_key_here

# --- Frontend → backend URL ---
VITE_API_URL=http://localhost:8080
